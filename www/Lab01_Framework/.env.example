# Tên ứng dụng hiển thị trong Laravel.
APP_NAME="Lab01 Framework"
# Chạy ở môi trường local trong quá trình học tập.
APP_ENV=local
# Khóa mã hóa sẽ được tạo bằng lệnh php artisan key:generate.
APP_KEY=
# Bật debug để xem lỗi khi phát triển.
APP_DEBUG=true
# URL khi chạy bằng php artisan serve.
APP_URL=http://localhost:8000
# Múi giờ Việt Nam để route /time trả thời gian chính xác.
APP_TIMEZONE=Asia/Ho_Chi_Minh
# Ngôn ngữ mặc định của ứng dụng.
APP_LOCALE=vi
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=vi_VN

# Sử dụng MySQL theo đúng yêu cầu bài thực hành.
DB_CONNECTION=mysql
# MySQL cục bộ thường chạy trên localhost.
DB_HOST=127.0.0.1
# Cổng mặc định của MySQL.
DB_PORT=3306
# Tên database bắt buộc theo yêu cầu: lab01framework.
DB_DATABASE=lab01framework
# Tài khoản mặc định của Laragon/XAMPP.
DB_USERNAME=root
# Laragon thường để mật khẩu root trống; sửa lại nếu máy đã đặt mật khẩu.
DB_PASSWORD=

# Dùng file cho session/cache để không cần tạo thêm bảng hệ thống.
SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file
QUEUE_CONNECTION=sync

# Ghi log ứng dụng vào storage/logs/laravel.log.
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug
